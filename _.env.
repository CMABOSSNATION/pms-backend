# ═══════════════════════════════════════════════════════════════════════════════
# PrisonCore — Environment Variables
# Copy this file to .env and fill in your values before running the app.
# On Render: add each variable via Dashboard → Your Service → Environment.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── DATABASE ─────────────────────────────────────────────────────────────────

# RENDER PRODUCTION — use the Internal Database URL from your Render Postgres dashboard.
# Dashboard → PostgreSQL service → Connections → Internal Database URL
DATABASE_URL="postgresql://pms_database_user:yourpassword@dpg-xxxx-a.oregon-postgres.render.com/pms_database"

# LOCAL development — install Postgres locally or use Docker:
#   docker run --name pms-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres
# Then set:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prisoncore"


# ─── SERVER ───────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development
# NODE_ENV=production   ← use this on Render


# ─── AUTHENTICATION ───────────────────────────────────────────────────────────

# JWT secret — MUST be changed to a long random string in production.
# Generate one with:  openssl rand -hex 64
JWT_SECRET="prisoncore-super-secret-jwt-key-change-this-in-production"

# How long tokens stay valid (e.g. 8h, 1d)
JWT_EXPIRES_IN="8h"

# Bcrypt salt rounds for password hashing (10–12 recommended)
BCRYPT_SALT_ROUNDS=12


# ─── OFFLINE / SYNC ───────────────────────────────────────────────────────────

# Milliseconds between sync retries when offline
SYNC_RETRY_INTERVAL_MS=30000

# Max retry attempts before a SyncQueue entry is marked FAILED
SYNC_MAX_RETRIES=5

# Days before a cached NIRA lookup expires and needs re-verification
NIRA_CACHE_TTL_DAYS=30


# ─── EXTERNAL INTEGRATIONS ────────────────────────────────────────────────────
# Leave blank for fully offline operation.
# The app falls back to locally cached data when these are empty.

# NIRA — National Identification and Registration Authority
NIRA_API_URL=
NIRA_API_KEY=

# eCMS — Electronic Case Management System
ECMS_API_URL=
ECMS_API_KEY=


# ─── CORS ─────────────────────────────────────────────────────────────────────

# Your frontend URL — used by the backend to allow cross-origin requests.
# Local development:
CLIENT_URL=http://localhost:5173
# Render production — replace with your actual frontend URL:
# CLIENT_URL=https://your-frontend.onrender.com


# ─── FRONTEND (Vite) ──────────────────────────────────────────────────────────
# Place these in your frontend/.env file (or frontend/.env.production for Render).

# Local development
VITE_API_URL=http://localhost:5000/api

# Render production — replace with your actual backend service URL
# VITE_API_URL=https://pms-backend-zpuv.onrender.com/api


# ═══════════════════════════════════════════════════════════════════════════════
# RENDER BUILD SETTINGS (set in Dashboard → Settings)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Build Command:
#   npm install && npx prisma generate && npx prisma migrate deploy && node src/config/seed.js
#
# Start Command:
#   npm start
#
# NOTE: No disk needed — Render's managed PostgreSQL handles all persistence.
# ═══════════════════════════════════════════════════════════════════════════════
