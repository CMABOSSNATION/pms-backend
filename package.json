{
  "name": "pms-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start":      "node src/server.js",
    "dev":        "nodemon src/server.js",
    "db:push":    "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed":    "node src/config/seed.js",
    "db:reset":   "prisma migrate reset --force && node src/config/seed.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs":       "^2.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "jsonwebtoken":   "^9.0.2",
    "morgan":         "^1.10.0",
    "prisma":         "^5.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
