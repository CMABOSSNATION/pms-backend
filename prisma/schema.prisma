// prisma/schema.prisma
// Database: PostgreSQL (production on Render)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS (Staff login accounts) ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String   @default("GUARD") // WARDEN | GUARD | MEDICAL | ADMIN | LEGAL | INVENTORY
  badgeNumber String   @unique
  shift       String   @default("DAY")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidents          Incident[]          @relation("ReportedBy")
  scans              ScanLog[]           @relation("ScannedBy")
  auditLogs          AuditLog[]
  movementAuthorized Movement[]          @relation("AuthorizedBy")
  custodySignatures  CustodyLog[]        @relation("OfficerSigned")
  medicationLogs     MedicationLog[]     @relation("DispenserBy")
  inventoryLogs      InventoryLog[]      @relation("LoggedBy")
}

// ─── PRISONERS ────────────────────────────────────────────────────────────────
model Prisoner {
  id          String    @id @default(cuid())
  prisonerId  String    @unique
  name        String
  age         Int
  crime       String
  sentence    String
  cellBlock   String
  cell        String
  status      String    @default("INCARCERATED") // INCARCERATED | RELEASED | TRANSFERRED | REMAND
  riskLevel   String    @default("MEDIUM")
  fingerprint String    @unique
  irisCode    String?
  entryDate   DateTime
  arrestDate  DateTime?
  releaseDate DateTime?
  photoUrl    String?
  notes       String?
  nationality String?
  nationalId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  incidents          Incident[]
  scans              ScanLog[]
  movements          Movement[]
  alerts             Alert[]
  visits             Visit[]
  medicalRecords     MedicalRecord[]
  vaccinations       Vaccination[]
  medications        MedicationLog[]
  rehabilitationLogs RehabilitationLog[]
  warrants           Warrant[]
  sentences          SentenceRecord[]
  hearings           CourtHearing[]
  custodyLogs        CustodyLog[]
  biometricLogs      BiometricLog[]
  ecmsCases          EcmsCase[]
  industryEnrollments IndustryEnrollment[]
  consentRecords     ConsentRecord[]
}

// ─── INCIDENTS ────────────────────────────────────────────────────────────────
model Incident {
  id          String    @id @default(cuid())
  incidentId  String    @unique
  type        String
  description String
  severity    String    @default("MEDIUM")
  location    String?
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
  reportedBy User     @relation("ReportedBy", fields: [userId], references: [id])
  userId     String
}

// ─── SCAN LOG ─────────────────────────────────────────────────────────────────
model ScanLog {
  id         String   @id @default(cuid())
  location   String
  riskLevel  String
  hasAlerts  Boolean  @default(false)
  createdAt  DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
  scannedBy  User     @relation("ScannedBy", fields: [userId], references: [id])
  userId     String
}

// ─── PRISONER MOVEMENTS ───────────────────────────────────────────────────────
model Movement {
  id             String   @id @default(cuid())
  from           String
  to             String
  reason         String?
  category       String   @default("INTERNAL") // INTERNAL | CLINIC | VISITOR | COURT | TRANSFER | EXERCISE
  escortBadge    String?
  returnedAt     DateTime?
  createdAt      DateTime @default(now())

  prisoner       Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId     String
  authorizedBy   User?    @relation("AuthorizedBy", fields: [authorizedById], references: [id])
  authorizedById String?
}

// ─── ALERTS ───────────────────────────────────────────────────────────────────
model Alert {
  id         String   @id @default(cuid())
  message    String
  severity   String   @default("MEDIUM")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── VISITOR MANAGEMENT ───────────────────────────────────────────────────────
model Visit {
  id           String   @id @default(cuid())
  visitorName  String
  relationship String
  visitDate    DateTime
  duration     Int      @default(30)
  status       String   @default("SCHEDULED")
  notes        String?
  createdAt    DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── MEDICAL RECORDS ──────────────────────────────────────────────────────────
model MedicalRecord {
  id             String    @id @default(cuid())
  type           String
  description    String
  treatment      String?
  medication     String?
  diagnosis      String?
  nextReview     DateTime?
  isConfidential Boolean   @default(true)
  createdAt      DateTime  @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── VACCINATION RECORDS ──────────────────────────────────────────────────────
model Vaccination {
  id          String   @id @default(cuid())
  vaccine     String
  doseNumber  Int      @default(1)
  givenDate   DateTime
  nextDueDate DateTime?
  givenBy     String
  batchNumber String?
  createdAt   DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── MEDICATION DISPENSING (eMAR) ─────────────────────────────────────────────
model MedicationLog {
  id             String   @id @default(cuid())
  medicationName String
  dosage         String
  dispensedAt    DateTime @default(now())
  scheduledAt    DateTime
  status         String   @default("DISPENSED") // DISPENSED | REFUSED | MISSED
  notes          String?

  prisoner      Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId    String
  dispensedBy   User     @relation("DispenserBy", fields: [dispensedById], references: [id])
  dispensedById String
}

// ─── REHABILITATION LOGS ──────────────────────────────────────────────────────
model RehabilitationLog {
  id          String   @id @default(cuid())
  programName String
  category    String   @default("VOCATIONAL") // VOCATIONAL | EDUCATION | COUNSELING | WORK | RELIGIOUS
  sessionDate DateTime
  attended    Boolean  @default(true)
  performance String?
  notes       String?
  instructor  String?
  createdAt   DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── WARRANT TRACKING ─────────────────────────────────────────────────────────
model Warrant {
  id            String   @id @default(cuid())
  warrantNumber String   @unique
  type          String   // ARREST | SEARCH | REMAND | PRODUCTION | RELEASE
  issuedBy      String
  courtName     String
  issuedDate    DateTime
  expiryDate    DateTime?
  status        String   @default("ACTIVE") // ACTIVE | EXECUTED | EXPIRED | CANCELLED
  documentUrl   String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── SENTENCE RECORDS ─────────────────────────────────────────────────────────
model SentenceRecord {
  id                 String   @id @default(cuid())
  offenseDescription String
  sentenceType       String   // CONCURRENT | CONSECUTIVE | SUSPENDED
  sentenceDuration   Int      // in days
  startDate          DateTime
  goodBehaviorDays   Int      @default(0)
  remissionDays      Int      @default(0)
  calculatedRelease  DateTime
  actualRelease      DateTime?
  isActive           Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── COURT HEARINGS ───────────────────────────────────────────────────────────
model CourtHearing {
  id             String    @id @default(cuid())
  hearingId      String    @unique
  courtName      String
  caseNumber     String
  hearingType    String    // BAIL | TRIAL | SENTENCING | APPEAL | MENTION | PAROLE
  scheduledAt    DateTime
  venue          String?
  judge          String?
  outcome        String?
  nextHearingAt  DateTime?
  notes          String?
  syncedAt       DateTime?
  externalRef    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── CHAIN OF CUSTODY (Inmate Property) ──────────────────────────────────────
model CustodyLog {
  id               String   @id @default(cuid())
  custodyId        String   @unique
  eventType        String   // INTAKE | RELEASE | TRANSFER | INSPECTION
  itemDescription  String
  itemCategory     String   @default("PERSONAL") // PERSONAL | VALUABLES | DOCUMENTS | CONTRABAND
  itemValue        Float?
  quantity         Int      @default(1)
  condition        String?
  storageLocation  String?
  officerSignature String?
  inmateSignature  String?
  signedAt         DateTime?
  notes            String?
  createdAt        DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
  officer    User     @relation("OfficerSigned", fields: [officerId], references: [id])
  officerId  String
}

// ─── BIOMETRIC LOGS ───────────────────────────────────────────────────────────
model BiometricLog {
  id          String   @id @default(cuid())
  scanType    String   // FINGERPRINT | IRIS | FACE
  scanPurpose String   // INTAKE | ROLL_CALL | ACCESS | VERIFICATION
  location    String
  deviceId    String?
  matchScore  Float?
  matched     Boolean  @default(true)
  rawHash     String?
  createdAt   DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────
model InventoryItem {
  id           String         @id @default(cuid())
  itemCode     String         @unique
  name         String
  category     String         // FOOD | UNIFORM | MEDICAL | ARMORY | MAINTENANCE | OFFICE
  unit         String         @default("units")
  currentStock Int            @default(0)
  minimumStock Int            @default(10)
  maximumStock Int            @default(500)
  unitCost     Float?
  supplier     String?
  location     String?
  isRestricted Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  logs         InventoryLog[]
}

model InventoryLog {
  id              String   @id @default(cuid())
  transactionType String   // IN | OUT | ADJUSTMENT | AUDIT
  quantity        Int
  balanceAfter    Int
  reason          String?
  referenceId     String?
  createdAt       DateTime @default(now())

  item       InventoryItem @relation(fields: [itemId], references: [id])
  itemId     String
  loggedBy   User          @relation("LoggedBy", fields: [loggedById], references: [id])
  loggedById String
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE | UPDATE | DELETE | LOGIN | SCAN | EXPORT | VIEW
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

// ─── NATIONAL INTEGRATIONS (NIRA / eCMS) ─────────────────────────────────────
model NiraLookup {
  id            String   @id @default(cuid())
  nationalId    String
  fullName      String?
  dob           String?
  gender        String?
  photoUrl      String?
  rawResponse   String?  // JSON blob from NIRA API
  matchedTo     String?  // prisoner prisonerId
  verifiedAt    DateTime @default(now())
  verifiedBy    String   // userId
}

model EcmsCase {
  id           String   @id @default(cuid())
  caseNumber   String   @unique
  prisonerId   String
  courtName    String
  judge        String?
  status       String   @default("OPEN") // OPEN | CLOSED | APPEALED
  charges      String?
  lastSyncedAt DateTime?
  rawData      String?  // Full JSON from eCMS
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  prisoner     Prisoner @relation(fields: [prisonerId], references: [id])
}

// ─── PRISON INDUSTRIES ───────────────────────────────────────────────────────
model Industry {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // FARMING | CARPENTRY | TAILORING | BAKERY | CRAFTS | LAUNDRY | PRINTING | OTHER
  description String?
  supervisor  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  enrollments IndustryEnrollment[]
  productions IndustryProduction[]
}

model IndustryEnrollment {
  id         String   @id @default(cuid())
  startDate  DateTime
  endDate    DateTime?
  status     String   @default("ACTIVE") // ACTIVE | COMPLETED | WITHDRAWN
  notes      String?
  createdAt  DateTime @default(now())

  prisoner   Prisoner @relation(fields: [prisonerId], references: [id])
  prisonerId String
  industry   Industry @relation(fields: [industryId], references: [id])
  industryId String
}

model IndustryProduction {
  id          String   @id @default(cuid())
  date        DateTime
  quantity    Float
  unit        String   // kg | units | metres | loaves | etc
  valueUGX    Float?
  notes       String?
  recordedBy  String   // userId
  createdAt   DateTime @default(now())

  industry    Industry @relation(fields: [industryId], references: [id])
  industryId  String
}

// ─── OFFLINE SYNC QUEUE ───────────────────────────────────────────────────────
model SyncQueue {
  id          String   @id @default(cuid())
  deviceId    String
  entity      String
  operation   String   // CREATE | UPDATE | DELETE
  payload     String   // JSON
  localId     String?
  serverIdMap String?  // maps localId → real server id after sync
  status      String   @default("PENDING") // PENDING | SYNCED | CONFLICT | FAILED
  conflictData String?
  createdAt   DateTime @default(now())
  syncedAt    DateTime?
}

// ─── DATA PRIVACY (Uganda DPA 2019) ──────────────────────────────────────────
model DataRequest {
  id           String   @id @default(cuid())
  requestType  String   // ACCESS | RECTIFICATION | ERASURE | RESTRICTION | PORTABILITY | OBJECTION
  subjectName  String
  subjectId    String?  // prisonerId or nationalId
  requestedBy  String   // Name of person making request
  relationship String?  // Self | Legal Rep | Family
  status       String   @default("PENDING") // PENDING | IN_REVIEW | FULFILLED | REJECTED
  notes        String?
  resolution   String?
  dueDate      DateTime // Must be resolved within 21 days per Uganda DPA
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  handledBy    String?  // userId of officer who resolved
}

model ConsentRecord {
  id          String   @id @default(cuid())
  prisonerId  String
  purpose     String   // BIOMETRIC_SCAN | MEDICAL_SHARE | NATIONAL_DB_SHARE | RESEARCH | LEGAL_SHARE
  granted     Boolean
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  notes       String?

  prisoner    Prisoner @relation(fields: [prisonerId], references: [id])
}
