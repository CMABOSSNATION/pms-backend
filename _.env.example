# ═══════════════════════════════════════════════════════════════════════════════
# PrisonCore — Environment Variables
# Copy this file to .env and fill in your values before running the app.
# On Render: add each variable via Dashboard → Your Service → Environment.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── DATABASE ─────────────────────────────────────────────────────────────────

# LOCAL development (SQLite file in project folder)
DATABASE_URL="file:./prisma/prisoncore.db"

# RENDER PRODUCTION — uncomment this line and comment out the one above.
# Requires a Render Persistent Disk mounted at /data (Dashboard → Disks → Add Disk,
# mount path: /data, size: 5 GB+). Without the disk, data is wiped on every deploy.
# DATABASE_URL="file:/data/prisoncore.db"


# ─── SERVER ───────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development
# NODE_ENV=production   ← use this on Render


# ─── AUTHENTICATION ───────────────────────────────────────────────────────────

# JWT secret — MUST be changed to a long random string in production.
# Generate one with:  openssl rand -hex 64
JWT_SECRET="prisoncore-super-secret-jwt-key-change-this-in-production"

# How long tokens stay valid (e.g. 8h, 1d)
JWT_EXPIRES_IN="8h"

# Bcrypt salt rounds for password hashing (10–12 recommended)
BCRYPT_SALT_ROUNDS=12


# ─── OFFLINE / SYNC ───────────────────────────────────────────────────────────

# Milliseconds between sync retries when offline
SYNC_RETRY_INTERVAL_MS=30000

# Max retry attempts before a SyncQueue entry is marked FAILED
SYNC_MAX_RETRIES=5

# Days before a cached NIRA lookup expires and needs re-verification
NIRA_CACHE_TTL_DAYS=30


# ─── EXTERNAL INTEGRATIONS ────────────────────────────────────────────────────
# Leave blank for fully offline operation.
# The app falls back to locally cached data when these are empty.

# NIRA — National Identification and Registration Authority
NIRA_API_URL=
NIRA_API_KEY=

# eCMS — Electronic Case Management System
ECMS_API_URL=
ECMS_API_KEY=


# ─── FRONTEND (Vite) ──────────────────────────────────────────────────────────
# Place these in your frontend/.env file (or frontend/.env.production for Render).

# Local development
VITE_API_URL=http://localhost:5000/api

# Render production — replace with your actual Render service URL
# VITE_API_URL=https://your-service-name.onrender.com/api
