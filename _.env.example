# ─── BACKEND ENVIRONMENT ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# SQLite local database — no internet required
DATABASE_URL="file:./prisma/prisoncore.db"

# JWT secret — change this to a long random string
JWT_SECRET="prisoncore-super-secret-jwt-key-change-this-in-production"

# Server port
PORT=5000

# Environment
NODE_ENV=development


# ─── FRONTEND ENVIRONMENT (.env in frontend folder) ────────────────────────────
# VITE_API_URL=http://localhost:5000/api
